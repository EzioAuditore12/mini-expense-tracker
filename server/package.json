{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "private": true,
  "keywords": [],
  "author": "",
  "license": "ISC",
  "scripts": {
    "build": "tsc && tsup",
    "dev": "node --import=tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:push": "npx drizzle-kit push",
    "db:pull": "npx drizzle-kit pull",
    "db:check": "npx drizzle-kit check",
    "db:up": "npx drizzle-kit up",
    "db:studio": "npx drizzle-kit studio --verbose",
    "seed:expense": "node --import=tsx seeders/expense.seeder.ts",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@faker-js/faker": "^10.4.0",
    "@node-rs/argon2": "^2.0.2",
    "@scalar/express-api-reference": "^0.9.20",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-error-toolkit": "^1.2.1",
    "express-rate-limit": "^8.5.2",
    "express-zod-safe": "^3.2.1",
    "helmet": "^8.2.0",
    "http-status-codes": "^2.3.0",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prettier-eslint": "^16.3.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "outDir": "dist",
    "format": [
      "esm",
      "cjs"
    ],
    "target": "es2020",
    "sourcemap": true,
    "clean": true,
    "dts": true,
    "splitting": false,
    "skipNodeModulesBundle": true
  }
}
